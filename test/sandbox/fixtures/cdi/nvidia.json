{
  "cdiVersion": "0.6.0",
  "kind": "nvidia.com/gpu",
  "containerEdits": {
    "env": ["NVIDIA_VISIBLE_DEVICES=void"],
    "mounts": [
      {
        "hostPath": "/usr/bin/nvidia-smi",
        "containerPath": "/usr/bin/nvidia-smi",
        "options": ["ro", "bind"]
      }
    ]
  },
  "devices": [
    {
      "name": "0",
      "containerEdits": {
        "env": ["NVIDIA_VISIBLE_DEVICES=0"],
        "deviceNodes": [
          { "path": "/dev/nvidia0" },
          { "path": "/dev/nvidiactl" }
        ]
      }
    },
    {
      "name": "1",
      "containerEdits": {
        "env": ["NVIDIA_VISIBLE_DEVICES=1"],
        "deviceNodes": [
          { "path": "/dev/nvidia1" },
          { "path": "/dev/nvidiactl" }
        ]
      }
    }
  ]
}
